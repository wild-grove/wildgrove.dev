---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<Layout title="Posts | Wild Grove">
	<div class="min-h-screen bg-neutral-950 text-gray-100 antialiased">
		<header class="border-b border-white/20 bg-black/100 backdrop-blur">
			<div class="container-page py-5 flex items-center justify-center">
				<a href="/" class="flex items-center justify-center gap-5 sm:gap-6">
					<img
						src="/assets/logo/v1/svg/main-symbol-transparent.svg"
						alt=""
						class="h-16 w-16 sm:h-20 sm:w-20"
					/>
					<span class="brand-wordmark text-[2.15rem] text-white sm:text-[2.85rem]">
						Wild Grove
					</span>
				</a>
			</div>
		</header>

		<main class="body-stage relative overflow-hidden">
			<div class="absolute inset-x-0 top-0 h-28 bg-gradient-to-b from-black via-black/65 to-transparent"></div>
			<div class="container-stage relative py-10 sm:py-14">
				<section class="floating-panel max-w-4xl p-6 sm:p-8">
					<p class="label-font text-xs uppercase tracking-[0.32em] text-white/45">Journal</p>
					<h1 class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl">Posts</h1>
					<p class="mt-4 max-w-2xl text-base leading-7 text-white/70">
						Notes, experiments, research, and updates for Wild Grove. Some posts may be more technical than others, 
						but all are written with a desire to share knowledge.
					</p>
					<ul class="mt-8 space-y-4 border-t border-white/8 pt-6">
						{posts.map((post) => (
							<li class="journal-entry">
								<a href={`/posts/${post.id}/`} class="block group">
									<div class="flex items-start justify-between gap-6">
										<h2 class="text-xl font-semibold text-white transition group-hover:text-white/80 sm:text-2xl">
											{post.data.title}
										</h2>
										<time class="muted whitespace-nowrap pt-1">
											{post.data.pubDate.toLocaleDateString("en-US", {
												year: "numeric",
												month: "short",
												day: "numeric",
											})}
										</time>
									</div>
									<p class="mt-3 max-w-2xl text-sm leading-7 text-white/70 sm:text-base">
										{post.data.description}
									</p>
								</a>
							</li>
						))}
					</ul>

					<div class="mt-8">
						<a href="/" class="link-arrow label-font">Back to home</a>
					</div>
				</section>
			</div>
		</main>

		<footer class="bg-neutral-900">
			<div class="container-page py-10 text-center text-sm text-white/60">
				<p>&copy; {new Date().getFullYear()} Wild Grove</p>
				<p class="mt-2">Khenon Walker | dev.kwalker@gmail.com</p>
			</div>
		</footer>
	</div>
</Layout>
