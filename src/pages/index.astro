---
import Layout from "../layouts/Layout.astro";
import repos from "../../content/curated/repos.json";
import resources from "../../content/curated/resources.json";
import highlights from "../../content/curated/highlights.json";

const categories = ["maker", "code dev", "garden", "research"];
const posts = [
	{ title: "Recent Post #1", date: "2025-09-03", href: "#" },
];
---

<Layout title="Wild Grove">
  	<div class="min-h-screen bg-neutral-950 text-gray-100 antialiased">
    	<!-- Header -->
    	<header class="border-b border-white/20 bg-black/100 backdrop-blur">
      		<div class="container-page py-5 flex items-center justify-center">
        	<a href="/" class="flex items-center justify-center gap-5 sm:gap-6">
				<img
					src="/assets/logo/v1/svg/main-symbol-transparent.svg"
					alt=""
					class="h-16 w-16 sm:h-20 sm:w-20"
				/>
				<span class="brand-wordmark text-[2.15rem] text-white sm:text-[2.85rem]">
					Wild Grove
				</span>
        	</a>
			</div>
    	</header>

		<!-- Categories -->
	<div class="container-page py-4">
        	<!-- Category chips -->
        	<nav class="hidden md:flex gap-2 justify-center flex">
          	{categories.map((c) => <a class="chip" href="#">{c}</a>)}
        	</nav>

      		<!-- Mobile chips row -->
      		<div class="md:hidden container-page pb-4 flex flex-wrap gap-2 justfiy-center">
        	{categories.map((c) => <a class="chip" href="#">{c}</a>)}
      		</div>
		</div>

		<main class="body-stage relative overflow-hidden">
			<div class="absolute inset-x-0 top-0 h-28 bg-gradient-to-b from-black via-black/65 to-transparent"></div>
			<div class="container-stage relative py-10 sm:py-14">
				<div class="grid grid-cols-1 gap-6 xl:grid-cols-[minmax(16rem,1.35fr)_minmax(0,4.3fr)_minmax(16rem,1.35fr)]">
					<aside class="order-2 space-y-6 xl:order-1">
						<section class="side-panel space-y-4">
							<div class="flex items-end justify-between gap-4">
								<div class="space-y-1">
									<p class="label-font text-xs uppercase tracking-[0.28em] text-white/45">Workspace</p>
								<h2 class="section-title label-font">Repos</h2>
								</div>
								<a href="/repos" class="link-arrow label-font text-sm">See all</a>
							</div>
							<ul class="space-y-3">
								{repos.map((r) => (
									<li>
										<a href={r.href} class="group flex items-start gap-3 rounded-2xl border border-white/8 bg-white/6 p-4 transition hover:bg-white/10">
											<div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-white/10 bg-white/8">
												<img src={`/icons/${r.img}`} alt="" class="h-7 w-7 invert" loading="lazy" />
											</div>
											<div class="min-w-0 flex-1">
												<h3 class="font-semibold text-white transition group-hover:text-white/80">{r.name}</h3>
												<p class="muted mt-1 line-clamp-2">{r.desc}</p>
											</div>
										</a>
									</li>
								))}
							</ul>
						</section>

						<section class="side-panel space-y-4">
							<div class="flex items-end justify-between gap-4">
								<div class="space-y-1">
								<h2 class="section-title label-font">Resources</h2>
								</div>
								<a href="/resources" class="link-arrow label-font text-sm">See all</a>
							</div>
							<ul class="space-y-3">
								{resources.map((r) => (
									<li>
										<a href={r.href} class="group flex items-start gap-3 rounded-2xl border border-white/8 bg-white/6 p-4 transition hover:bg-white/10">
											<div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-white/10 bg-white/8">
												<img src={`/icons/${r.img}`} alt="" class="h-7 w-7 invert" loading="lazy" />
											</div>
											<div class="min-w-0 flex-1">
												<h3 class="font-semibold text-white transition group-hover:text-white/80">{r.name}</h3>
												<p class="muted mt-1 leading-6">{r.desc}</p>
											</div>
										</a>
									</li>
								))}
							</ul>
						</section>
					</aside>

					<section class="order-1 xl:order-2">
						<div class="floating-panel p-5 sm:p-7">
							<div class="flex items-end justify-between gap-6">
								<div class="space-y-2">
									<p class="label-font text-xs uppercase tracking-[0.32em] text-white/45">Posts</p>
									<h2 class="text-2xl font-semibold tracking-tight text-white sm:text-3xl">Recent Posts</h2>
									<p class="max-w-2xl text-sm text-white/60 sm:text-base">
										Notes, experiments, research, and updates.
									</p>
								</div>
								<a href="/posts" class="link-arrow label-font hidden sm:inline">See all posts</a>
							</div>

							<ul class="mt-6 space-y-4 border-t border-white/8 pt-6">
								{posts.map((p) => (
									<li class="journal-entry">
										<a href={p.href} class="block group">
											<div class="flex items-start justify-between gap-6">
												<h3 class="text-xl font-semibold text-white transition group-hover:text-white/80 sm:text-2xl">
													{p.title}
												</h3>
												<time class="muted whitespace-nowrap pt-1">{p.date}</time>
											</div>
											<p class="mt-3 max-w-2xl text-sm leading-7 text-white/70 sm:text-base">
												One-sentence teaser goes here.
											</p>
										</a>
									</li>
								))}
							</ul>

							<div class="mt-5 sm:hidden">
								<a href="/posts" class="link-arrow label-font">See all posts</a>
							</div>
						</div>
					</section>

					<aside class="order-3">
						<section class="side-panel space-y-4">
							<div class="space-y-1">
								<p class="label-font text-xs uppercase tracking-[0.28em] text-white/45">Highlights</p>
								<h2 class="section-title label-font">Worth Exploring</h2>
							</div>
							<ul class="space-y-3">
								{highlights.map((h) => (
									<li>
										<a
											href={h.href}
											class="block rounded-2xl border border-white/8 bg-white/6 px-4 py-5 text-white/85 transition hover:bg-white/10 hover:text-white"
										>
											<h3 class="text-base font-semibold">{h.name}</h3>
										</a>
									</li>
								))}
							</ul>
						</section>
					</aside>
				</div>
			</div>
		</main>

    	<footer class="bg-neutral-900">
			<div class="container-page py-10 text-center text-sm text-white/60">
				<p>&copy; {new Date().getFullYear()} Wild Grove</p>
				<p class="mt-2">Khenon Walker | dev.kwalker@gmail.com</p>
			</div>
    	</footer>
  	</div>
</Layout>
